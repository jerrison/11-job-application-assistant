def cmd_prioritize(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import get_job, init_db, log_event
    conn = init_db(jobs_db_path())
    job = get_job(conn, args.job_id)
    if not job:
        print(f"Job {args.job_id} not found.")
        conn.close()
        return 1
    conn.execute("UPDATE jobs SET priority = 10 WHERE id = ?", (args.job_id,))
    log_event(conn, args.job_id, "priority_change", detail="priority set to 10",
              initiator="cli")
    conn.commit()
    print(f"Job {args.job_id} priority bumped to 10.")
    conn.close()
    return 0


def _focused_aerospace_workspace(*, environ: dict[str, str] | None = None) -> str | None:
    return submit_browser_aerospace_workspace(environ=environ)


def cmd_worker(args: argparse.Namespace) -> int:
    pid_file = jobs_db_path().with_name("jobs.db.worker.pid")
    action = args.action

    if action == "start":
        cmd = python_script_command(SCRIPTS_ROOT / "job_worker.py")
        cmd.extend(["--workers", str(args.workers)])
        if args.headless:
            cmd.append("--headless")
        if args.auto_submit:
            cmd.append("--auto-submit")
        env = os.environ.copy()
        aerospace_workspace = _focused_aerospace_workspace(environ=env)
        if aerospace_workspace:
            env[JOB_ASSETS_AEROSPACE_WORKSPACE_ENV] = aerospace_workspace
        proc = subprocess.Popen(cmd, start_new_session=True, cwd=REPO_ROOT, env=env)
        pid_file.write_text(str(proc.pid), encoding="utf-8")
        print(f"Worker started (PID {proc.pid}).")
        return 0

    if action == "stop":
        if not pid_file.exists():
            print("No worker PID file found.")
            return 1
        pid = int(pid_file.read_text(encoding="utf-8").strip())
        try:
            os.kill(pid, signal.SIGTERM)
            print(f"Sent SIGTERM to worker (PID {pid}).")
            pid_file.unlink(missing_ok=True)
        except ProcessLookupError:
            print(f"Worker (PID {pid}) is not running.")
            pid_file.unlink(missing_ok=True)
        return 0

    if action == "status":
        if not pid_file.exists():
            print("No worker running (no PID file).")
            return 0
        pid = int(pid_file.read_text(encoding="utf-8").strip())
        try:
            os.kill(pid, 0)
            print(f"Worker is running (PID {pid}).")
        except ProcessLookupError:
            print(f"Worker (PID {pid}) is not running (stale PID file).")
            pid_file.unlink(missing_ok=True)
        return 0

    return 1


def cmd_report(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import (
        get_all_job_metrics,
        get_board_error_rates,
        get_field_corrections,
        get_job,
        get_job_metrics,
        get_jobs_processed_counts,
        get_phase_avg_durations,
        get_summary_stats,
        init_db,
        query_jobs,
    )
    conn = init_db(jobs_db_path())

    # Single job detail mode
    if hasattr(args, 'job') and args.job:
        job = get_job(conn, args.job)
        if not job:
            print(f"Job {args.job} not found.")
            conn.close()
            return 1
        print(f"Job {job['id']}: {job.get('company') or '?'} — {job.get('role_title') or '?'}")
        print(f"  Status: {job['status']}  Board: {job.get('board') or '-'}  Provider: {job.get('provider') or '-'}")
        m = get_job_metrics(conn, args.job)
        if m:
            dur_s = (m['total_duration_ms'] or 0) / 1000
            print(f"  Duration: {dur_s:.0f}s  Fields: {m['fields_corrected']}/{m['total_fields']}  "
                  f"Error Rate: {m['field_error_rate'] * 100:.0f}%")
            print(f"  Fixes: {m['auto_fix_attempts']}  Interventions: {m['manual_interventions']}  "
                  f"Retries: {m['retry_count']}  Phases: {m['phase_count']}")
        phases = conn.execute(
            "SELECT phase, duration_ms, exit_code FROM job_phase_durations WHERE job_id = ? ORDER BY id",
            (args.job,),
        ).fetchall()
        if phases:
            print("  Phases:")
            for p in phases:
                dur = f"{(p['duration_ms'] or 0) / 1000:.1f}s"
                ec = f"exit={p['exit_code']}" if p['exit_code'] is not None else ""
                print(f"    {p['phase']:15s}  {dur:>8s}  {ec}")
        corrections = get_field_corrections(conn, args.job)
        if corrections:
            print(f"  Field Corrections ({len(corrections)}):")
            for fc in corrections:
                print(f"    [{fc['correction_source']}] {fc['field_name']}: "
                      f"{(fc['original_value'] or '-')[:40]} → {(fc['corrected_value'] or '-')[:40]}")
        conn.close()
        return 0

    # CSV export mode
    if args.format == "csv":
        import csv
        import io
        all_metrics = get_all_job_metrics(conn, board=args.board, status=args.status)
        out = io.StringIO()
        writer = csv.writer(out)
        writer.writerow([
            "job_id", "company", "role", "status", "board", "total_fields",
            "fields_corrected", "error_rate", "manual_interventions",
            "auto_fix_attempts", "total_duration_ms", "retry_count",
        ])
        for m in all_metrics:
            writer.writerow([
                m["job_id"], m.get("company", ""), m.get("role_title", ""),
                m.get("status", ""), m.get("board", ""), m["total_fields"],
                m["fields_corrected"], f"{m['field_error_rate']:.3f}",
                m["manual_interventions"], m["auto_fix_attempts"],
                m["total_duration_ms"], m["retry_count"],
            ])
        print(out.getvalue(), end="")
        conn.close()
        return 0

    # JSON export mode
    if args.format == "json":
        kwargs: dict = {}
        if args.status:
            kwargs["status"] = args.status
        if args.board:
            kwargs["board"] = args.board
        jobs = query_jobs(conn, **kwargs, limit=9999)
        if args.since:
            jobs = [j for j in jobs if j["created_at"] and j["created_at"] >= args.since]
        print(json.dumps(jobs, indent=2, default=str))
        conn.close()
        return 0

    # Default: summary + table
    summary = get_summary_stats(conn, since=args.since)
    processed = get_jobs_processed_counts(conn)

    print("=== Job Pipeline Report ===")
    print(f"Processed:  1h={processed['last_1h']}  24h={processed['last_24h']}  "
          f"7d={processed['last_7d']}  all={processed['all_time']}")
    print(f"Total: {summary['total']}  Submitted: {summary['submitted']}  "
          f"Failed: {summary['failed']}  Attention: {summary['needs_attention']}")
    print(f"Success Rate: {summary['success_rate'] * 100:.1f}%  "
          f"Failure Rate: {summary['failure_rate'] * 100:.1f}%")
    print(f"Intervention Rate: {summary['intervention_rate'] * 100:.1f}%  "
          f"Avg Error Rate: {summary['avg_error_rate'] * 100:.1f}%")
    dur_s = (summary['avg_duration_ms'] or 0) / 1000
    print(f"Avg Duration: {dur_s:.0f}s")

    phase_avgs = get_phase_avg_durations(conn)
    if phase_avgs:
        print("\nPhase Avg Durations:")
        for phase in ("resolve", "generate", "submit", "fix", "retry", "post_submit"):
            avg = phase_avgs.get(phase)
            if avg is not None:
                print(f"  {phase:15s}  {avg / 1000:.1f}s")

    board_rates = get_board_error_rates(conn)
    if board_rates:
        print("\nBoard Error Rates:")
        for board, rate in sorted(board_rates.items(), key=lambda x: x[1], reverse=True):
            print(f"  {board:15s}  {rate * 100:.0f}%")

    kwargs: dict = {}
    if args.status:
        kwargs["status"] = args.status
    if args.board:
        kwargs["board"] = args.board
    jobs = query_jobs(conn, **kwargs, limit=9999)
    if args.since:
        jobs = [j for j in jobs if j["created_at"] and j["created_at"] >= args.since]
    if jobs:
        print(f"\n{'ID':>5}  {'Status':<18}  {'Board':<12}  {'Company':<20}  {'Role':<30}  {'Created'}")
        print("-" * 105)
        for j in jobs:
            print(
                f"{j['id']:>5}  {j['status']:<18}  {(j['board'] or '-'):<12}  "
                f"{(j['company'] or '-'):<20}  {(j['role_title'] or '-'):<30}  {j['created_at']}"
            )

    conn.close()
    return 0


def cmd_tui(args: argparse.Namespace) -> int:
    if args.clean:
        # Kill orphaned workers and pipelines before launching
        for pattern in ("job_worker", "apply.sh"):
            subprocess.run(["pkill", "-f", pattern], capture_output=True)
        # Reset stuck in-progress jobs
        sys.path.insert(0, str(SCRIPTS_ROOT))
        from job_db import init_db, reset_stale_jobs
        conn = init_db(jobs_db_path())
        reset = reset_stale_jobs(conn, stale_threshold_seconds=0)
        conn.close()
        if reset:
            print(f"Reset {len(reset)} stuck job(s) to queued")
    cmd = python_script_command(SCRIPTS_ROOT / "job_tui.py")
    return run_command(cmd)


