def cmd_install(args: argparse.Namespace) -> int:
    bin_dir = Path(os.path.expanduser(args.bin_dir)).resolve()
    man_dir = Path(os.path.expanduser(args.man_dir)).resolve()
    commands = ["job-assets", "job-assets-codex", "job-assets-claude"]
    man_pages = ["job-assets.1", "job-assets-codex.1", "job-assets-claude.1"]

    if args.dry_run:
        print(f"Would install commands into: {bin_dir}")
        for name in commands:
            print(f"  {bin_dir / name} -> {SCRIPT_PATH}")
        if not args.no_man:
            print(f"Would install man pages into: {man_dir}")
            for page in man_pages:
                print(f"  {man_dir / page} -> {MAN1_ROOT / page}")
        return 0

    bin_dir.mkdir(parents=True, exist_ok=True)
    for name in commands:
        install_link(SCRIPT_PATH, bin_dir / name)

    if not args.no_man:
        man_dir.mkdir(parents=True, exist_ok=True)
        for page in man_pages:
            install_link(MAN1_ROOT / page, man_dir / page)

    print(f"Installed commands into {bin_dir}")
    if not args.no_man:
        print(f"Installed man pages into {man_dir}")
    print("Try: job-assets --help")
    print("Try: man job-assets")
    return 0


def cmd_man(args: argparse.Namespace) -> int:
    topic = args.topic or default_man_topic()
    env = os.environ.copy()
    current = env.get("MANPATH", "")
    env["MANPATH"] = f"{MAN_ROOT}:{current}" if current else str(MAN_ROOT)
    return run_command(["man", topic], env=env)


def _open_job_db() -> sqlite3.Connection:
    """Open (and initialise) the shared job queue database."""
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import init_db  # noqa: E402
    return init_db(jobs_db_path())


def _resolve_job(conn, target: str) -> dict:
    """Resolve a target (job ID or URL) to a job dict. Exits on failure."""
    from job_db import get_job
    # Try as integer job ID first
    try:
        job_id = int(target)
        job = get_job(conn, job_id)
        if job:
            return job
    except ValueError:
        pass
    # Try as URL
    row = conn.execute("SELECT * FROM jobs WHERE url = ? OR canonical_url = ?", (target, target)).fetchone()
    if row:
        return dict(row)
    print(f"Job not found: {target}", file=sys.stderr)
    sys.exit(1)


def _format_age(timestamp_str: str | None) -> str:
    """Format a timestamp string as a human-readable age (e.g., '2h ago', '3d ago')."""
    if not timestamp_str:
        return "?"
    from datetime import datetime
    try:
        # SQLite CURRENT_TIMESTAMP format
        dt = datetime.fromisoformat(timestamp_str.replace(" ", "T"))
        if dt.tzinfo is None:
            dt = dt.replace(tzinfo=UTC)
        delta = datetime.now(UTC) - dt
        seconds = int(delta.total_seconds())
        if seconds < 60:
            return f"{seconds}s ago"
        minutes = seconds // 60
        if minutes < 60:
            return f"{minutes}m ago"
        hours = minutes // 60
        if hours < 24:
            return f"{hours}h ago"
        days = hours // 24
        return f"{days}d ago"
    except (ValueError, TypeError):
        return "?"


# ── Draft subcommands ────────────────────────────────────────────────────────


def cmd_draft_list(args: argparse.Namespace) -> int:
    conn = _open_job_db()
    rows = conn.execute(
        "SELECT id, company, role_title, board, updated_at FROM jobs WHERE status = 'draft' ORDER BY updated_at DESC"
    ).fetchall()
    if not rows:
        print("No drafts pending review.")
        conn.close()
        return 0
    header = f"{'ID':>5}  {'Company':<20}  {'Role':<30}  {'Board':<12}  {'Age'}"
    print(header)
    print("-" * len(header))
    for row in rows:
        age = _format_age(row["updated_at"])
        print(
            f"{row['id']:>5}  {(row['company'] or '?'):<20}  "
            f"{(row['role_title'] or '?'):<30}  {(row['board'] or '?'):<12}  {age}"
        )
    conn.close()
    return 0


def cmd_draft_review(args: argparse.Namespace) -> int:
    conn = _open_job_db()
    job = _resolve_job(conn, args.target)
    if not job["output_dir"]:
        print(f"Job #{job['id']} has no output directory.", file=sys.stderr)
        conn.close()
        return 1
    out_dir = Path(job["output_dir"])
    summary_path = out_dir / "draft_summary.md"

    if not summary_path.exists():
        print(f"No draft summary found at {summary_path}", file=sys.stderr)
        conn.close()
        return 1

    if args.edit:
        conn.close()
        editor = os.environ.get("EDITOR", "vi")
        os.execvp(editor, [editor, str(summary_path)])
    else:
        print(summary_path.read_text(encoding="utf-8"))
        # Show image paths
        for img in out_dir.glob("*.png"):
            print(f"\nImage: {img}")
    conn.close()
    return 0


def cmd_draft_approve(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    conn = _open_job_db()
    job = _resolve_job(conn, args.target)
    from pipeline_orchestrator import approve_job, approve_job_failure_message
    if not approve_job(conn, job["id"]):
        print(approve_job_failure_message(conn, job["id"]), file=sys.stderr)
        conn.close()
        return 1
    print(f"Job #{job['id']} approved — worker will submit it.")
    conn.close()
    return 0


def cmd_draft_reject(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    conn = _open_job_db()
    job = _resolve_job(conn, args.target)
    from job_db import update_status
    update_status(conn, job["id"], "stopped", error_message="Draft rejected via CLI")
    print(f"Draft #{job['id']} rejected -> stopped.")
    conn.close()
    return 0


def cmd_draft_regenerate(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    conn = _open_job_db()
    job = _resolve_job(conn, args.target)
    if not job["output_dir"]:
        print(f"Job #{job['id']} has no output directory.", file=sys.stderr)
        conn.close()
        return 1
    out_dir = Path(job["output_dir"])

    from draft_manager import apply_draft_edits, classify_draft_edits

    original_path = out_dir / "draft_summary.original.md"
    edited_path = out_dir / "draft_summary.md"
    if not original_path.exists() or not edited_path.exists():
        print(f"Draft summary files not found in {out_dir}", file=sys.stderr)
        conn.close()
        return 1

    original = original_path.read_text(encoding="utf-8")
    edited = edited_path.read_text(encoding="utf-8")
    changes = classify_draft_edits(original, edited)

    if changes:
        result = apply_draft_edits(out_dir, changes)
        print(f"Detected {len(changes)} change(s).")
        if "fix_report_path" in result:
            print(f"Fix report: {result['fix_report_path']}")
            from pipeline_orchestrator import auto_fix
            auto_fix(
                {"fix_report": result["fix_report_path"], "board": job["board"]},
                job["board"],
            )

    from pipeline_orchestrator import process_job, regenerate_job
    if regenerate_job(conn, job["id"]):
        print(f"Regenerating draft #{job['id']}...")
        process_job(conn, job["id"])
    else:
        print(f"Job #{job['id']} is not in draft status.", file=sys.stderr)
        conn.close()
        return 1
    conn.close()
    return 0


def cmd_draft_serve(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    try:
        from draft_web import create_app
    except ImportError:
        print("Web dependencies not installed. Run: uv pip install -e '.[web]'", file=sys.stderr)
        return 1
    app = create_app()
    import uvicorn
    uvicorn.run(app, host="127.0.0.1", port=args.port)
    return 0


def cmd_add(args: argparse.Namespace) -> int:
    if args.saved_portal and args.urls:
        print(
            f"Use positional URLs or --saved-portal {saved_portal_choices_text()}, not both.",
            file=sys.stderr,
        )
        return 2

    if args.saved_portal:
        try:
            result = _import_saved_portal(args.saved_portal, priority=args.priority, provider=args.provider)
        except Exception as exc:  # noqa: BLE001
            print(f"Saved portal import failed: {exc}", file=sys.stderr)
            return 1
        _print_saved_portal_summary(args.saved_portal, result)
        return 0 if result.get("status") == "ok" else 1

    if not args.urls:
        print(
            f"Provide one or more URLs, or use --saved-portal {saved_portal_choices_text()}.",
            file=sys.stderr,
        )
        return 2

    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import add_job, init_db

    conn = init_db(jobs_db_path())
    try:
        for url in args.urls:
            job_id = add_job(conn, url, priority=args.priority, provider=args.provider)
            print(f"Queued job {job_id}: {url}")
    finally:
        conn.close()
    return 0


def _import_saved_portal(saved_portal: str, *, priority: int, provider: str | None) -> dict:
    _maybe_reexec_saved_portal_with_uv()
    sys.path.insert(0, str(SCRIPTS_ROOT))
    module = saved_portal_import.load_saved_portal_module(saved_portal)
    conn = _open_job_db()
    try:
        return module.import_saved_jobs(conn, priority=priority, provider=provider)
    finally:
        conn.close()


def _maybe_reexec_saved_portal_with_uv() -> None:
    if os.environ.get("JOB_ASSETS_SAVED_PORTAL_BOOTSTRAPPED") == "1":
        return
    if importlib.util.find_spec("playwright") is not None:
        return
    if not shutil.which("uv"):
        return

    env = os.environ.copy()
    env["JOB_ASSETS_SAVED_PORTAL_BOOTSTRAPPED"] = "1"
    cmd = ["uv", "run", "--project", str(REPO_ROOT), "python", str(SCRIPT_PATH), *sys.argv[1:]]
    raise SystemExit(subprocess.call(cmd, cwd=REPO_ROOT, env=env))


def _maybe_reexec_cli_with_uv() -> None:
    if os.environ.get(_CLI_BOOTSTRAP_ENV) == "1":
        return
    if importlib.util.find_spec("pdfplumber") is not None:
        return
    if not shutil.which("uv"):
        return

    env = os.environ.copy()
    env[_CLI_BOOTSTRAP_ENV] = "1"
    cmd = ["uv", "run", "--project", str(REPO_ROOT), "python", str(SCRIPT_PATH), *sys.argv[1:]]
    raise SystemExit(subprocess.call(cmd, cwd=REPO_ROOT, env=env))


def _print_saved_portal_summary(saved_portal: str, result: dict) -> None:
    label = saved_portal_import.get_saved_portal(saved_portal).label
    status = result.get("status", "unknown")
    scraped = result.get("scraped", 0)
    resolved = result.get("resolved", 0)
    added = result.get("added", 0)
    duplicates = result.get("duplicates", 0)
    unresolved = result.get("skipped_unresolved", 0)
    errors = result.get("errors", 0)
    print(
        f"{label} import: status={status} scraped={scraped} resolved={resolved} "
        f"added={added} duplicates={duplicates} unresolved={unresolved} errors={errors}"
    )
    message = str(result.get("message") or "").strip()
    if message:
        print(f"Message: {message}")


def cmd_queue(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import get_status_counts, init_db, query_jobs
    conn = init_db(jobs_db_path())
    counts = get_status_counts(conn)
    if counts:
        summary = ", ".join(f"{s}: {c}" for s, c in sorted(counts.items()))
        print(f"Queue summary: {summary}")
        print()
    jobs = query_jobs(
        conn,
        status=args.status,
        board=args.board,
        source=args.source,
        search=args.search,
        limit=args.limit,
    )
    if not jobs:
        print("No jobs found.")
        conn.close()
        return 0
    # Column-aligned table output
    header = (
        f"{'ID':>5}  {'Status':<18}  {'Entered UTC':<23}  {'Board':<12}  "
        f"{'Company':<20}  {'Role':<30}  URL"
    )
    print(header)
    print("-" * len(header))
    for j in jobs:
        print(
            f"{j['id']:>5}  {j['status']:<18}  {_format_utc_timestamp(j.get('status_entered_at')):<23}  "
            f"{(j['board'] or '-'):<12}  "
            f"{(j['company'] or '-'):<20}  {(j['role_title'] or '-'):<30}  {j['url']}"
        )
    conn.close()
    return 0


def cmd_status(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import get_job, get_job_timeline, init_db
    conn = init_db(jobs_db_path())
    job = get_job(conn, args.job_id)
    if not job:
        print(f"Job {args.job_id} not found.")
        conn.close()
        return 1
    print(f"Job {job['id']}")
    print(f"  URL:          {job['url']}")
    print(f"  Status:       {job['status']}")
    print(f"  Board:        {job['board'] or '-'}")
    print(f"  Company:      {job['company'] or '-'}")
    print(f"  Role:         {job['role_title'] or '-'}")
    print(f"  Provider:     {job['provider'] or '-'}")
    print(f"  Priority:     {job['priority']}")
    print(f"  Source:       {job['source'] or '-'}")
    print(f"  Output dir:   {job['output_dir'] or '-'}")
    print(f"  Error:        {job['error_message'] or '-'}")
    print(f"  Fix attempts: {job['fix_attempts']}")
    print(f"  Status since: {_format_utc_timestamp(job.get('status_entered_at'))}")
    print(f"  Created:      {_format_utc_timestamp(job.get('created_at'))}")
    print(f"  Updated:      {_format_utc_timestamp(job.get('updated_at'))}")
    print(f"  Completed:    {_format_utc_timestamp(job.get('completed_at'))}")
    timeline = get_job_timeline(conn, args.job_id)
    if timeline:
        print()
        print("Timeline:")
        for ev in timeline:
            detail = ev["detail"] or ""
            print(f"  [{_format_utc_timestamp(ev['created_at'])}] {ev['event_type']}: {detail}")
    conn.close()
    return 0


