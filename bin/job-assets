def preprocess_argv(argv: list[str]) -> list[str]:
    if not argv:
        return argv
    first = argv[0]
    if first == "help":
        return ["--help"]
    if first in {"-h", "--help"}:
        return argv

    positional_index = first_positional_index(argv)
    if positional_index is None:
        return argv

    command = argv[positional_index]
    if command in KNOWN_COMMANDS:
        if positional_index == 0:
            return argv
        return [command, *argv[:positional_index], *argv[positional_index + 1 :]]

    return ["pipeline", *argv]


def first_positional_index(argv: list[str]) -> int | None:
    index = 0
    while index < len(argv):
        token = argv[index]
        if token == "--":
            return index + 1 if index + 1 < len(argv) else None
        if token.startswith("--"):
            option = token.split("=", 1)[0]
            if "=" not in token and option in OPTIONS_WITH_VALUES:
                index += 2
            else:
                index += 1
            continue
        if token.startswith("-"):
            index += 1
            continue
        return index
    return None


def repo_command(path: str) -> str:
    return str(REPO_ROOT / path)


def python_script_command(path: str) -> list[str]:
    script = repo_command(path)
    if shutil.which("uv"):
        return ["uv", "run", "--project", str(REPO_ROOT), "python", script]
    return [sys.executable, script]


def run_command(cmd: list[str], env: dict[str, str] | None = None) -> int:
    completed = run_worker_subprocess(cmd, cwd=REPO_ROOT, env=env)
    return completed.returncode


def add_provider_option(parser: argparse.ArgumentParser, *, default: str) -> None:
    parser.add_argument(
        "--provider",
        choices=VALID_PROVIDERS,
        default=default,
        help=f"LLM provider to use (default: {default})",
    )


def install_link(src: Path, dest: Path) -> None:
    if dest.is_symlink() or dest.exists():
        dest.unlink()
    dest.symlink_to(src)


def cmd_apply(args: argparse.Namespace) -> int:
    cmd = ["bash", repo_command("apply.sh"), "--provider", args.provider]
    if args.skip_sync:
        cmd.append("--skip-sync")
    cmd.append(args.jd_source)
    if args.company:
        cmd.append(args.company)
    if args.role:
        cmd.append(args.role)
    return run_command(cmd)


def cmd_pipeline(args: argparse.Namespace) -> int:
    cmd = [*python_script_command("scripts/job_assets_pipeline.py"), "--provider", args.provider]
    if args.skip_sync:
        cmd.append("--skip-sync")
    if args.browser_provider:
        cmd.extend(["--browser-provider", args.browser_provider])
    if args.payload_only:
        cmd.append("--payload-only")
    if args.headless:
        cmd.append("--headless")
    if args.submit:
        cmd.append("--submit")
    if args.reapply:
        cmd.append("--reapply")
    cmd.append(args.jd_source)
    if args.company:
        cmd.append(args.company)
    if args.role:
        cmd.append(args.role)
    return run_command(cmd)


def cmd_submit(args: argparse.Namespace) -> int:
    cmd = [*python_script_command("scripts/submit_application.py"), args.target]
    if args.payload_only:
        cmd.append("--payload-only")
    if args.headless:
        cmd.append("--headless")
    if args.submit:
        cmd.append("--submit")
    if args.reapply:
        cmd.append("--reapply")
    if args.provider:
        cmd.extend(["--provider", args.provider])
    env = os.environ.copy()
    if args.browser_provider:
        env["JOB_ASSETS_BROWSER_PROVIDER"] = args.browser_provider
    return run_command(cmd, env=env)


def cmd_batch(args: argparse.Namespace) -> int:
    cmd = [
        "bash",
        repo_command("batch_apply.sh"),
        "--provider",
        args.provider,
        "--max-parallel",
        str(args.max_parallel),
    ]
    if args.dry_run:
        cmd.append("--dry-run")
    env = os.environ.copy()
    env["JOB_ASSETS_MAX_PARALLEL"] = str(args.max_parallel)
    return run_command(cmd, env=env)


def cmd_parallel(args: argparse.Namespace) -> int:
    cmd = [
        "bash",
        repo_command("parallel_apply.sh"),
        "--provider",
        args.provider,
        "--max-parallel",
        str(args.max_parallel),
    ]
    if args.dry_run:
        cmd.append("--dry-run")
    if args.build_only:
        cmd.append("--build-only")
    env = os.environ.copy()
    env["JOB_ASSETS_MAX_PARALLEL"] = str(args.max_parallel)
    env["MAX_PARALLEL"] = str(args.max_parallel)
    return run_command(cmd, env=env)


