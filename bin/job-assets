def cmd_settings_show(args: argparse.Namespace) -> int:
    store = _settings_store_module()
    payload = {
        "settings": store.load_settings(),
        "bootstrap": store.load_bootstrap(),
    }
    if args.json:
        _print_json(payload)
        return 0

    print(f"settings root: {materials_root()}")
    print(f"onboarding complete: {payload['bootstrap']['onboarding']['complete']}")
    for key, meta in payload["settings"]["materials"].items():
        state = "ready" if meta["has_content"] else "missing"
        print(f"{key}: {state} ({meta['path']})")
    configured = [key for key, meta in payload["settings"]["credentials"].items() if meta["configured"]]
    print(f"configured credentials: {', '.join(configured) if configured else 'none'}")
    return 0


def cmd_settings_import(args: argparse.Namespace) -> int:
    store = _settings_store_module()
    import_kwargs: dict[str, object] = {}
    if args.text is not None:
        import_kwargs["text"] = args.text
    elif args.url is not None:
        import_kwargs["source_url"] = args.url
    elif args.file is not None:
        path = Path(args.file).expanduser()
        import_kwargs["file_name"] = path.name
        import_kwargs["content_bytes"] = path.read_bytes()
    else:
        raise ValueError("Provide one import source: --text, --url, or --file")

    result = store.import_material(args.material_key, **import_kwargs)
    if args.json:
        _print_json(result)
    else:
        print(
            f"{args.material_key} imported; onboarding_complete="
            f"{result['bootstrap']['onboarding']['complete']}"
        )
    return 0


def cmd_settings_set(args: argparse.Namespace) -> int:
    store = _settings_store_module()
    providers = {
        key: value
        for key, value in {
            "default_provider": args.default_provider,
            "provider_chain": args.provider_chain,
            "openai_model": args.openai_model,
            "gemini_model": args.gemini_model,
            "gemini_flash_model": args.gemini_flash_model,
            "codex_model": args.codex_model,
            "claude_model": args.claude_model,
            "steel_base_url": args.steel_base_url,
            "steel_local": args.steel_local,
        }.items()
        if value is not None
    }
    credentials = {
        key: value
        for key, value in {
            "openai_api_key": args.openai_api_key,
            "openai_api_keys": args.openai_api_keys,
            "gemini_api_key": args.gemini_api_key,
            "codex_api_key": args.codex_api_key,
            "anthropic_api_key": args.anthropic_api_key,
            "steel_api_key": args.steel_api_key,
        }.items()
        if value is not None
    }
    settings = store.save_settings({"providers": providers, "credentials": credentials})
    if args.json:
        _print_json(settings)
    else:
        print("settings updated")
    return 0


