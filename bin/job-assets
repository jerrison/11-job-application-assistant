def saved_portal_choices() -> tuple[str, ...]:
    return tuple(spec.key for spec in saved_portal_import.list_saved_portals())


def saved_portal_choices_text() -> str:
    return "|".join(saved_portal_choices())


def default_provider() -> str:
    return PROVIDER_ALIASES.get(COMMAND_NAME, default_active_provider())


def default_max_parallel() -> int:
    for key in ("JOB_ASSETS_MAX_PARALLEL", "MAX_PARALLEL"):
        raw = os.environ.get(key, "").strip()
        if not raw:
            continue
        try:
            return max(int(raw), 1)
        except ValueError:
            continue
    cpu_count = os.cpu_count() or 4
    return max(4, min(cpu_count * 2, 16))


def _format_utc_timestamp(ts: str | None) -> str:
    if not ts:
        return "-"
    if ts.endswith(" UTC"):
        return ts
    return f"{ts} UTC"


def default_man_topic() -> str:
    return COMMAND_NAME if COMMAND_NAME in {"job-assets-codex", "job-assets-claude"} else "job-assets"


def command_prefix() -> str:
    return COMMAND_NAME


