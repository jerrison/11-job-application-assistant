def _detect_role_status(role_dir: Path) -> str:
    """Detect the correct job status from filesystem artifacts.

    Checks submission result files, confirmation files, content files, and
    draft artifacts to determine whether a job was submitted, is in draft,
    or is still generating.
    Works with both old layout (files in root) and new layout (content/ + submit/).
    """
    submit_dir = role_dir / "submit"
    content_dir = role_dir / "content"

    _RESULT_STATUS_MAP = {
        "confirmed": "submitted",
        "submitted": "submitted",
        "skipped_captcha": "skipped_captcha",
        "skipped_auth": "skipped_auth",
        "failed": "failed",
    }

    # Check application_submission_result.json (most authoritative source)
    for candidate in [submit_dir] + sorted(role_dir.glob("submit-*")):
        result_path = candidate / "application_submission_result.json"
        if result_path.exists():
            try:
                data = json.loads(result_path.read_text(encoding="utf-8"))
                mapped = _RESULT_STATUS_MAP.get(data.get("status", ""))
                if mapped:
                    return mapped
            except (json.JSONDecodeError, OSError):
                pass

    # Check for website confirmation in submit/ or submit-*/ directories
    for candidate in [submit_dir] + sorted(role_dir.glob("submit-*")):
        if (candidate / "application_confirmation_website.json").exists():
            return "submitted"

    # Check for confirmation in old layout (files in root)
    if (role_dir / "application_confirmation_website.json").exists():
        return "submitted"

    # Check for completed materials (draft status)
    for base in (content_dir, role_dir):
        has_resume = (base / "resume_content.json").exists()
        has_cl = (base / "cover_letter_text.txt").exists()
        if has_resume and has_cl:
            return "draft"

    # Check for draft in progress
    for base in (content_dir, role_dir):
        if (base / "resume_content_draft.json").exists():
            return "generating"

    return "queued"


def cmd_import(args: argparse.Namespace) -> int:
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import add_job, init_db, update_status
    output_dir = Path(args.output_dir).resolve()
    if not output_dir.is_dir():
        print(f"Output directory not found: {output_dir}")
        return 1
    conn = init_db(jobs_db_path())
    imported = 0
    for company_dir in sorted(output_dir.iterdir()):
        if not company_dir.is_dir():
            continue
        for role_dir in sorted(company_dir.iterdir()):
            if not role_dir.is_dir():
                continue
            meta_path = role_dir / ".pipeline_meta.json"
            if not meta_path.exists():
                continue
            try:
                meta = json.loads(meta_path.read_text(encoding="utf-8"))
            except (json.JSONDecodeError, OSError):
                continue
            url = meta.get("jd_url") or meta.get("jd_source_url") or meta.get("jd_source_resolved") or meta.get("jd_source") or meta.get("url", "")
            if not url or not url.startswith("http"):
                continue
            company = meta.get("company", company_dir.name)
            role = meta.get("jd_title") or meta.get("role_title") or meta.get("role_slug", role_dir.name)
            board = meta.get("board")
            status = _detect_role_status(role_dir)
            try:
                job_id = add_job(conn, url, priority=0)
            except Exception:
                # Likely duplicate canonical_url
                continue
            update_status(
                conn,
                job_id,
                status,
                company=company,
                role_title=role,
                board=board,
                output_dir=str(role_dir),
            )
            imported += 1
    print(f"Imported {imported} jobs from {output_dir}")
    conn.close()
    return 0


def cmd_sync(args: argparse.Namespace) -> int:
    """Sync all jobs from on-disk artifacts into the database.

    Reads submission results, confirmations, Notion sync status, autofill
    reports, and error details from output directories and updates the
    corresponding database records.
    """
    sys.path.insert(0, str(SCRIPTS_ROOT))
    from job_db import init_db, sync_all_jobs_from_disk
    conn = init_db(jobs_db_path())
    result = sync_all_jobs_from_disk(conn)
    print(f"Synced {result['synced']} of {result['total']} jobs from disk artifacts")

    # Show final status distribution
    counts = conn.execute(
        "SELECT status, COUNT(*) FROM jobs GROUP BY status ORDER BY COUNT(*) DESC"
    ).fetchall()
    print()
    for s, c in counts:
        print(f"  {s:<20} {c:>3}")
    conn.close()
    return 0


def build_parser() -> argparse.ArgumentParser:
    provider = default_provider()
    description = (
        "Generate tailored job application assets without opening an interactive Codex or Claude session first.\n\n"
        "URL-based runs fail fast if the website scrape does not produce a usable JD.\n\n"
        "Single-job shortcut: if the first positional argument is a JD URL or file path, the command runs the "
        "end-to-end pipeline flow and stops at review unless you add --submit.\n\n"
        "Use 'apply' only when you explicitly want assets without launching submit automation.\n\n"
        f"Default provider: {provider}\n\n"
        f"Examples:\n"
        f"  {command_prefix()} https://boards.greenhouse.io/company/jobs/12345\n"
        f"  {command_prefix()} --submit https://boards.greenhouse.io/company/jobs/12345\n"
        f"  {command_prefix()} apply tmp/jd.md acme senior-pm\n"
        f"  {command_prefix()} pipeline --submit https://boards.greenhouse.io/company/jobs/12345\n"
        f"  {command_prefix()} submit output/acme/senior-pm --submit\n"
        f"  {command_prefix()} batch --max-parallel 6\n"
        f"  {command_prefix()} parallel --max-parallel 6\n"
        f"  {command_prefix()} settings show\n"
        f"  {command_prefix()} settings import master_resume --file ~/resume.docx\n"
        f"  {command_prefix()} settings set --openai-api-key sk-... --gemini-api-key ai-...\n"
        f"  {command_prefix()} profile show\n"
        f"  {command_prefix()} notion-sync output/company/role-slug\n"
        f"  {command_prefix()} man\n"
    )

    parser = argparse.ArgumentParser(
        prog=COMMAND_NAME,
        description=description,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    apply_parser = subparsers.add_parser(
        "apply",
        help="Generate resume and cover letter assets only for a single job posting",
    )
    add_provider_option(apply_parser, default=default_provider())
    apply_parser.add_argument(
        "--skip-sync",
        action="store_true",
        help="Skip syncing work_stories.md and candidate_context.md before generation.",
    )
    apply_parser.add_argument("jd_source", help="Job description source: URL or local file")
    apply_parser.add_argument("company", nargs="?", help="Optional company slug override")
    apply_parser.add_argument("role", nargs="?", help="Optional role slug override")
    apply_parser.set_defaults(func=cmd_apply)

    pipeline_parser = subparsers.add_parser(
        "pipeline",
        help="Run the full single-job flow: generate assets, then continue into supported board autofill/submission",
    )
    add_provider_option(pipeline_parser, default=default_provider())
    pipeline_parser.add_argument(
        "--skip-sync",
        action="store_true",
        help="Skip syncing work_stories.md and candidate_context.md before generation.",
    )
    pipeline_parser.add_argument(
        "--browser-provider",
        choices=("local", "steel"),
        default=None,
        help="Browser runtime to use for submit automation (default: env or local).",
    )
    pipeline_parser.add_argument(
        "--payload-only",
        action="store_true",
        help="Generate the board-specific autofill payload after assets are built, but do not launch the browser.",
    )
    pipeline_parser.add_argument(
        "--headless",
        action="store_true",
        help="Launch the Playwright runtime in headless mode during the submit stage.",
    )
    pipeline_parser.add_argument(
        "--submit",
        action="store_true",
        help="Submit the application after autofill. Without this flag, the browser stops at a review state.",
    )
    pipeline_parser.add_argument(
        "--reapply",
        action="store_true",
        help="Start or continue one fresh submit-* reapply artifact directory for this role.",
    )
    pipeline_parser.add_argument("jd_source", help="Job description source: URL or local file")
    pipeline_parser.add_argument("company", nargs="?", help="Optional company slug override")
    pipeline_parser.add_argument("role", nargs="?", help="Optional role slug override")
    pipeline_parser.set_defaults(func=cmd_pipeline)

    submit_parser = subparsers.add_parser(
        "submit",
        help="Run board-specific application autofill and optional submission for an existing output directory",
    )
    add_provider_option(submit_parser, default=default_provider())
    submit_parser.add_argument(
        "target",
        help="Output directory or job URL already present in .pipeline_meta.json",
    )
    submit_parser.add_argument(
        "--browser-provider",
        choices=("local", "steel"),
        default=None,
        help="Browser runtime to use for submit automation (default: env or local).",
    )
    submit_parser.add_argument(
        "--payload-only",
        action="store_true",
        help="Only generate the board-specific autofill payload.",
    )
    submit_parser.add_argument(
        "--headless",
        action="store_true",
        help="Launch the Playwright runtime in headless mode.",
    )
    submit_parser.add_argument(
        "--submit",
        action="store_true",
        help="Submit the application after autofill. Default behavior stops for review.",
    )
    submit_parser.add_argument(
        "--reapply",
        action="store_true",
        help="Start or continue one fresh submit-* reapply artifact directory for this role.",
    )
    submit_parser.set_defaults(func=cmd_submit)

    batch_parser = subparsers.add_parser(
        "batch",
        help="Run the high-throughput batch flow for all discovered jobs",
    )
    add_provider_option(batch_parser, default=default_provider())
    batch_parser.add_argument("--dry-run", action="store_true", help="List jobs without processing them")
    batch_parser.add_argument(
        "--max-parallel",
        type=int,
        default=default_max_parallel(),
        help="Maximum concurrent LLM jobs (default: %(default)s)",
    )
    batch_parser.set_defaults(func=cmd_batch)

    parallel_parser = subparsers.add_parser(
        "parallel",
        help="Run the parallel batch flow for all discovered jobs",
    )
    add_provider_option(parallel_parser, default=default_provider())
    parallel_parser.add_argument("--dry-run", action="store_true", help="List jobs without processing them")
    parallel_parser.add_argument("--build-only", action="store_true", help="Skip LLM generation and only build documents")
    parallel_parser.add_argument(
        "--max-parallel",
        type=int,
        default=default_max_parallel(),
        help="Maximum concurrent LLM jobs (default: %(default)s)",
    )
    parallel_parser.set_defaults(func=cmd_parallel)

    doctor_parser = subparsers.add_parser(
        "doctor",
        help="Show installation and provider diagnostics",
    )
    doctor_parser.set_defaults(func=cmd_doctor)

    settings_parser = subparsers.add_parser(
        "settings",
        help="Show and update shared onboarding materials, providers, and API keys",
    )
    settings_sub = settings_parser.add_subparsers(dest="settings_command", required=True)

    settings_show_parser = settings_sub.add_parser(
        "show",
        help="Print the current shared settings state",
    )
    settings_show_parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    settings_show_parser.set_defaults(func=cmd_settings_show)

    settings_import_parser = settings_sub.add_parser(
        "import",
        help="Import one shared onboarding material from text, a file, or a public URL",
    )
    settings_import_parser.add_argument("material_key", choices=_settings_material_keys())
    import_source_group = settings_import_parser.add_mutually_exclusive_group(required=True)
    import_source_group.add_argument("--file", help="Local file path to import")
    import_source_group.add_argument("--url", help="Public Google Drive/Docs link or other fetchable URL")
    import_source_group.add_argument("--text", help="Literal text or markdown content")
    settings_import_parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    settings_import_parser.set_defaults(func=cmd_settings_import)

    settings_set_parser = settings_sub.add_parser(
        "set",
        help="Update shared provider defaults and API credentials",
    )
    settings_set_parser.add_argument("--default-provider", choices=VALID_PROVIDERS)
    settings_set_parser.add_argument("--provider-chain")
    settings_set_parser.add_argument("--openai-model")
    settings_set_parser.add_argument("--gemini-model")
    settings_set_parser.add_argument("--gemini-flash-model")
    settings_set_parser.add_argument("--codex-model")
    settings_set_parser.add_argument("--claude-model")
    settings_set_parser.add_argument("--steel-base-url")
    settings_set_parser.add_argument("--steel-local", action="store_true", default=None)
    settings_set_parser.add_argument("--steel-remote", dest="steel_local", action="store_false")
    settings_set_parser.add_argument("--openai-api-key")
    settings_set_parser.add_argument("--openai-api-keys")
    settings_set_parser.add_argument("--gemini-api-key")
    settings_set_parser.add_argument("--codex-api-key")
    settings_set_parser.add_argument("--anthropic-api-key")
    settings_set_parser.add_argument("--steel-api-key")
    settings_set_parser.add_argument("--json", action="store_true", help="Print machine-readable JSON")
    settings_set_parser.set_defaults(func=cmd_settings_set)

    profile_parser = subparsers.add_parser(
        "profile",
        help="Show the editable application-profile defaults file or print its path",
    )
    profile_parser.add_argument(
        "profile_action",
        nargs="?",
        choices=("show", "path"),
        default="show",
        help="Show the file contents or print its path (default: %(default)s)",
    )
    profile_parser.set_defaults(func=cmd_profile)

    notion_sync_parser = subparsers.add_parser(
        "notion-sync",
        help="Sync a website-confirmed application into the Notion tracker after the email confirmation arrives",
    )
    notion_sync_parser.add_argument(
        "target",
        help="Output directory (e.g. output/company/role-slug) or a job URL already present in .pipeline_meta.json",
    )
    notion_sync_parser.add_argument(
        "--wait-for-email",
        type=int,
        default=90,
        help="Seconds to wait for the confirmation email before leaving the sync pending (default: %(default)s)",
    )
    notion_sync_parser.add_argument(
        "--allow-pending-email",
        action="store_true",
        help="Exit successfully if the website confirmation exists but the email confirmation has not arrived yet",
    )
    notion_sync_parser.add_argument(
        "--strict-token",
        action="store_true",
        help="Exit non-zero when NOTION_API_TOKEN is missing instead of writing a pending status artifact",
    )
    notion_sync_parser.set_defaults(func=cmd_notion_sync)

    install_parser = subparsers.add_parser(
        "install",
        help="Install command symlinks and man pages into standard locations",
    )
    install_parser.add_argument(
        "--bin-dir",
        default="~/.local/bin",
        help="Directory for command symlinks (default: %(default)s)",
    )
    install_parser.add_argument(
        "--man-dir",
        default="/opt/homebrew/share/man/man1",
        help="Directory for man page symlinks (default: %(default)s)",
    )
    install_parser.add_argument("--no-man", action="store_true", help="Skip man page installation")
    install_parser.add_argument("--dry-run", action="store_true", help="Show planned changes without writing anything")
    install_parser.set_defaults(func=cmd_install)

    man_parser = subparsers.add_parser(
        "man",
        help="Open the bundled man page without requiring global installation",
    )
    man_parser.add_argument(
        "topic",
        nargs="?",
        choices=("job-assets", "job-assets-codex", "job-assets-claude"),
        help="Manual page topic (default depends on the command name)",
    )
    man_parser.set_defaults(func=cmd_man)

    # --- Job queue management commands ---

    add_parser = subparsers.add_parser(
        "add",
        help="Queue one or more job URLs for processing",
    )
    add_parser.add_argument("urls", nargs="*", help="Job posting URLs to queue")
    add_parser.add_argument(
        "--priority",
        type=int,
        default=0,
        help="Priority level (higher = processed sooner, default: %(default)s)",
    )
    add_parser.add_argument(
        "--saved-portal",
        choices=saved_portal_choices(),
        help="Import jobs from a saved-job portal instead of positional URLs",
    )
    add_provider_option(add_parser, default=default_provider())
    add_parser.set_defaults(func=cmd_add)

    queue_parser = subparsers.add_parser(
        "queue",
        help="Show the current job queue with status summary",
    )
    queue_parser.add_argument("--status", help="Filter by job status")
    queue_parser.add_argument("--board", help="Filter by job board")
    queue_parser.add_argument("--source", help="Filter by source (e.g. linkedin, direct)")
    queue_parser.add_argument("--search", help="Search company or role title")
    queue_parser.add_argument(
        "--limit",
        type=int,
        default=100,
        help="Maximum number of jobs to show (default: %(default)s)",
    )
    queue_parser.set_defaults(func=cmd_queue)

    status_parser = subparsers.add_parser(
        "status",
        help="Show detailed information and timeline for a specific job",
    )
    status_parser.add_argument("job_id", type=int, help="Job ID to inspect")
    status_parser.set_defaults(func=cmd_status)

    retry_parser = subparsers.add_parser(
        "retry",
        help="Re-queue a failed job for retry",
    )
    retry_parser.add_argument("job_id", type=int, help="Job ID to retry")
    retry_parser.set_defaults(func=cmd_retry)

    skip_parser = subparsers.add_parser(
        "skip",
        help="Mark a job as skipped (needs manual handling)",
    )
    skip_parser.add_argument("job_id", type=int, help="Job ID to skip")
    skip_parser.set_defaults(func=cmd_skip)

    prioritize_parser = subparsers.add_parser(
        "prioritize",
        help="Bump a job's priority to 10 so it is processed next",
    )
    prioritize_parser.add_argument("job_id", type=int, help="Job ID to prioritize")
    prioritize_parser.set_defaults(func=cmd_prioritize)

    worker_parser = subparsers.add_parser(
        "worker",
        help="Start, stop, or check the background job worker",
    )
    worker_parser.add_argument(
        "action",
        choices=("start", "stop", "status"),
        help="Worker action to perform",
    )
    worker_parser.add_argument(
        "--workers",
        type=int,
        default=3,
        help="Number of concurrent workers (default: %(default)s)",
    )
    worker_parser.add_argument(
        "--headless",
        action="store_true",
        help="Run browser automation in headless mode",
    )
    worker_parser.add_argument(
        "--auto-submit",
        action="store_true",
        help="Bypass draft review, submit immediately after autofill",
    )
    worker_parser.set_defaults(func=cmd_worker)

    report_parser = subparsers.add_parser(
        "report",
        help="Query and export job results",
    )
    report_parser.add_argument("--job", type=int, help="Show detailed metrics for a specific job ID")
    report_parser.add_argument("--board", help="Filter by job board")
    report_parser.add_argument("--status", help="Filter by job status")
    report_parser.add_argument("--since", help="Show jobs created on or after this timestamp (ISO format)")
    report_parser.add_argument(
        "--format",
        choices=("table", "json", "csv"),
        default="table",
        help="Output format (default: %(default)s)",
    )
    report_parser.set_defaults(func=cmd_report)

    linkedin_login_parser = subparsers.add_parser(
        "linkedin-login",
        help="Log in to LinkedIn in a browser to enable URL resolution for LinkedIn job links",
    )
    linkedin_login_parser.set_defaults(func=cmd_linkedin_login)

    tui_parser = subparsers.add_parser(
        "tui",
        help="Launch the interactive terminal UI for job queue management",
    )
    tui_parser.add_argument(
        "--clean", action="store_true",
        help="Kill orphaned workers, reset stuck jobs, then launch fresh",
    )
    tui_parser.set_defaults(func=cmd_tui)

    web_parser = subparsers.add_parser(
        "web",
        help="Launch the web UI for job queue management",
    )
    web_parser.add_argument("--host", default="127.0.0.1",
                           help="Bind host (use 0.0.0.0 for LAN access)")
    web_parser.add_argument("--port", type=int, default=8420,
                           help="Port (default: %(default)s)")
    web_parser.add_argument("--workers", type=int, default=16,
                           help="Number of job workers (default: %(default)s)")
    web_parser.add_argument("--with-workers", action="store_true",
                           help="Auto-start workers with the web server (default: workers run independently)")
    web_parser.set_defaults(func=cmd_web)

    import_parser = subparsers.add_parser(
        "import",
        help="Import existing output directories into the job database",
    )
    import_parser.add_argument(
        "--output-dir",
        default=str(REPO_ROOT / "output"),
        help="Root output directory to scan (default: %(default)s)",
    )
    import_parser.set_defaults(func=cmd_import)

    sync_parser = subparsers.add_parser(
        "sync",
        help="Sync on-disk submission artifacts into the database",
    )
    sync_parser.set_defaults(func=cmd_sync)

    # --- Draft review commands ---

    draft_parser = subparsers.add_parser("draft", help="Draft review commands")
    draft_sub = draft_parser.add_subparsers(dest="draft_command", required=True)

    draft_list_parser = draft_sub.add_parser("list", help="List jobs in draft status")
    draft_list_parser.set_defaults(func=cmd_draft_list)

    draft_review_parser = draft_sub.add_parser("review", help="Show draft summary for a job")
    draft_review_parser.add_argument("target", help="Job ID or URL")
    draft_review_parser.add_argument("--edit", action="store_true", help="Open draft_summary.md in $EDITOR")
    draft_review_parser.set_defaults(func=cmd_draft_review)

    draft_approve_parser = draft_sub.add_parser("approve", help="Approve draft and submit")
    draft_approve_parser.add_argument("target", help="Job ID or URL")
    draft_approve_parser.set_defaults(func=cmd_draft_approve)

    draft_reject_parser = draft_sub.add_parser("reject", help="Reject draft -> stopped")
    draft_reject_parser.add_argument("target", help="Job ID or URL")
    draft_reject_parser.set_defaults(func=cmd_draft_reject)

    draft_regen_parser = draft_sub.add_parser("regenerate", help="Process edits and regenerate draft")
    draft_regen_parser.add_argument("target", help="Job ID or URL")
    draft_regen_parser.set_defaults(func=cmd_draft_regenerate)

    draft_serve_parser = draft_sub.add_parser("serve", help="Start web review server")
    draft_serve_parser.add_argument("--port", type=int, default=8420, help="Port to listen on (default: %(default)s)")
    draft_serve_parser.add_argument(
        "--tunnel",
        choices=("cloudflare", "ngrok"),
        default=None,
        help="Expose via tunnel (optional)",
    )
    draft_serve_parser.set_defaults(func=cmd_draft_serve)

    return parser


def main() -> int:
    abort_if_recursive_entrypoints_forbidden(COMMAND_NAME)
    _maybe_reexec_cli_with_uv()
    configure_runtime_trace(environ=os.environ, replace=True)
    parser = build_parser()
    argv = preprocess_argv(sys.argv[1:])
    args = parser.parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    raise SystemExit(main())
